{
    "test_update_feature_flag__200": {
        "url": "/feature-flags/{feature_flag_id}?project_id={project_id}",
        "method": "PUT",
        "status": 200,
        "request": {
            "name": "tony",
            "description": "ooooooo!",
            "enabled": true,
            "conditions": [[{
                "context_key": "tony",
                "operator": 12,
                "value": "soprano"
            }]]
        },
        "response": {
            "_id": null,
            "name": "tony",
            "description": "ooooooo!",
            "enabled": true,
            "conditions": [[{
                "context_key": "tony",
                "operator": 12,
                "value": "soprano"
            }]],
            "created_date": null,
            "updated_date": null
        }
    },
    "test_update_feature_flag__404": {
        "url": "/feature-flags/{feature_flag_id}?project_id={project_id}",
        "method": "PUT",
        "status": 404,
        "request": {
            "name": "tony",
            "description": "ooooooo!",
            "enabled": true,
            "conditions": [[{
                "context_key": "tony",
                "operator": 12,
                "value": "soprano"
            }]]
        },
        "response": {
            "errors": [{
                "code": "NOT_FOUND",
                "message": "Resource not found."
            }]
        }
    },
    "test_update_feature_flag__400_name_taken": {
        "url": "/feature-flags/{feature_flag_id}?project_id={project_id}",
        "method": "PUT",
        "status": 400,
        "request": {
            "name": "tony",
            "description": "ooooooo!",
            "enabled": true,
            "conditions": [[{
                "context_key": "tony",
                "operator": 12,
                "value": "soprano"
            }]]
        },
        "response": {
            "errors": [{
                "code": "NAME_TAKEN",
                "field": "name",
                "message": "Sorry, that name is already taken."
            }]
        }
    }
}
