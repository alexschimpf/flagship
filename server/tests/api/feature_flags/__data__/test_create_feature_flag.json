{
    "test_create_feature_flag__200": {
        "url": "/feature-flags?project_id={project_id}",
        "method": "POST",
        "status": 200,
        "request": {
            "name": "tony",
            "description": "ooooooo!",
            "enabled": true,
            "conditions": []
        },
        "response": {
            "_id": null,
            "name": "tony",
            "description": "ooooooo!",
            "enabled": true,
            "conditions": [],
            "created_date": null,
            "updated_date": null
        }
    },
    "test_create_feature_flag__400_name_taken": {
        "url": "/feature-flags?project_id={project_id}",
        "method": "POST",
        "status": 400,
        "request": {
            "name": "tony",
            "description": "ooooooo!",
            "enabled": true,
            "conditions": []
        },
        "response": {
            "errors": [{
                "code": "NAME_TAKEN",
                "field": "name",
                "message": "Sorry, that name is already taken."
            }]
        }
    },
    "test_create_feature_flag__400_invalid_conditions": {
        "url": "/feature-flags?project_id={project_id}",
        "method": "POST",
        "status": 400,
        "request": {
            "name": "tony",
            "description": "ooooooo!",
            "enabled": true,
            "conditions": null
        },
        "response": {
            "errors": [
                {
                    "code": "INVALID_FEATURE_FLAG_CONDITIONS",
                    "field": "conditions",
                    "message": "Invalid conditions."
                }
            ]
        }
    }
}
